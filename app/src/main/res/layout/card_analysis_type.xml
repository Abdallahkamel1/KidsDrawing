<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layoutDirection="ltr"
    android:background="@drawable/curved_text"
    android:paddingBottom="20dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:orientation="vertical">
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="20dp"
            android:text="Choose Analysis Type"
            android:gravity="center"
            android:textColor="@color/purpulecolor"
            android:textStyle="bold"
            android:textSize= "24sp"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_doctor"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginVertical="10dp"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/button_yellow"
            android:padding="8dp"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_gravity="center"
            android:textColor="#FFFFFF"
            android:text="Analysis by Doctor" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_ai"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="30dp"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/button_red"
            android:padding="8dp"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_gravity="center"
            android:textColor="#FFFFFF"
            android:text="Analysis using AI" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
